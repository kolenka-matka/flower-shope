# дроп и пересоздание бд:
# docker exec -it rut-postgres psql -U postgres -c "DROP DATABASE flower_shop_dev;"
# docker exec -it rut-postgres psql -U postgres -c "CREATE DATABASE flower_shop_dev;"

@host = http://localhost:5210

### ---------------------------------------------------------------------
### 0. Проверка API
### ---------------------------------------------------------------------
GET {{host}}/
Accept: application/json


### =====================================================================
### 1. ЗАПОЛНЕНИЕ: ЦВЕТЫ (фиксированные id для удобства)
### =====================================================================

### Роза красная
POST {{host}}/api/flowers
Content-Type: application/json

{
  "id": "f0000000-0000-0000-0000-000000000001",
  "name": "Роза красная",
  "color": "красный",
  "price": 250,
  "stock": 100
}

### Тюльпан розовый
POST {{host}}/api/flowers
Content-Type: application/json

{
  "id": "f0000000-0000-0000-0000-000000000002",
  "name": "Тюльпан розовый",
  "color": "розовый",
  "price": 90,
  "stock": 110
}

### Лилия белая
POST {{host}}/api/flowers
Content-Type: application/json

{
  "id": "f0000000-0000-0000-0000-000000000003",
  "name": "Лилия белая",
  "color": "белый",
  "price": 300,
  "stock": 40
}

### Зелень: эвкалипт (техническая зелень — обычная позиция склада)
POST {{host}}/api/flowers
Content-Type: application/json

{
  "id": "f0000000-0000-0000-0000-000000000004",
  "name": "Эвкалипт",
  "color": "зелёный",
  "price": 60,
  "stock": 200
}

### Хризантема белая (малый остаток — для теста нехватки)
POST {{host}}/api/flowers
Content-Type: application/json

{
  "id": "f0000000-0000-0000-0000-000000000005",
  "name": "Хризантема белая",
  "color": "белый",
  "price": 80,
  "stock": 5
}

### Орхидея премиум (дорогая — чтобы быстро поднять клиента до Gold)
POST {{host}}/api/flowers
Content-Type: application/json

{
  "id": "f0000000-0000-0000-0000-000000000006",
  "name": "Орхидея премиум",
  "color": "фиолетовый",
  "price": 6000,
  "stock": 50
}


### =====================================================================
### 2. ЗАПОЛНЕНИЕ: КЛИЕНТЫ
### =====================================================================

### Анна — обычный клиент (Bronze), на ней тестируем базовый заказ и отказ VIP-промокода
POST {{host}}/api/clients
Content-Type: application/json

{
  "id": "c0000000-0000-0000-0000-000000000001",
  "fullName": "Анна Иванова",
  "phone": "+79001234567",
  "address": "Москва, ул. Цветочная 1",
  "loyaltyPoints": 0
}

### Мария — будущий VIP. Сделает крупный заказ и дорастёт до Gold
POST {{host}}/api/clients
Content-Type: application/json

{
  "id": "c0000000-0000-0000-0000-000000000002",
  "fullName": "Мария Богатова",
  "phone": "+79009998877",
  "address": "Москва, Рублёвское шоссе 10",
  "loyaltyPoints": 0
}


### =====================================================================
### 3. ЗАПОЛНЕНИЕ: КУРЬЕРЫ
### =====================================================================

### Курьер 1 — лимит 3 активных заказа
POST {{host}}/api/couriers
Content-Type: application/json

{
  "id": "a0000000-0000-0000-0000-000000000001",
  "fullName": "Дмитрий Петров",
  "phone": "+79001112233",
  "maxActiveOrders": 3
}

### Курьер 2 — лимит 5
POST {{host}}/api/couriers
Content-Type: application/json

{
  "id": "a0000000-0000-0000-0000-000000000002",
  "fullName": "Сергей Соколов",
  "phone": "+79004445566",
  "maxActiveOrders": 5
}


### =====================================================================
### 4. ЗАПОЛНЕНИЕ: ПРОМОКОДЫ
### =====================================================================

### SPRING20 — обычный, скидка 20%
POST {{host}}/api/promocodes
Content-Type: application/json

{
  "id": "d0000000-0000-0000-0000-000000000001",
  "code": "SPRING20",
  "discountPercent": 20,
  "validUntil": "2026-12-31T23:59:59Z",
  "usageLimit": 100,
  "isVipOnly": false
}

### VIP30 — только для Gold/Platinum, скидка 30%
POST {{host}}/api/promocodes
Content-Type: application/json

{
  "id": "d0000000-0000-0000-0000-000000000002",
  "code": "VIP30",
  "discountPercent": 30,
  "validUntil": "2026-12-31T23:59:59Z",
  "usageLimit": 50,
  "isVipOnly": true
}


### =====================================================================
### 5. ЗАПОЛНЕНИЕ: БУКЕТ (состав = роза + 2 тюльпана + эвкалипт, наценка 400)
### =====================================================================
POST {{host}}/api/bouquets
Content-Type: application/json

{
  "id": "b0000000-0000-0000-0000-000000000001",
  "name": "Букет «Нежность»",
  "description": "Роза, тюльпаны и эвкалипт",
  "flowerIds": [
    "f0000000-0000-0000-0000-000000000001",
    "f0000000-0000-0000-0000-000000000002",
    "f0000000-0000-0000-0000-000000000002",
    "f0000000-0000-0000-0000-000000000004"
  ],
  "markup": 400
}


### =====================================================================
### СЦЕНАРИЙ A. Простой заказ (2 розы + 1 тюльпан) у Анны
### =====================================================================

# @name orderSimple
POST {{host}}/api/orders
Content-Type: application/json

{
  "clientId": "c0000000-0000-0000-0000-000000000001",
  "flowerIds": [
    "f0000000-0000-0000-0000-000000000001",
    "f0000000-0000-0000-0000-000000000001",
    "f0000000-0000-0000-0000-000000000002"
  ],
  "bouquetIds": [],
  "deliveryAddress": "Москва, Тверская 5"
}
### Ожидаем 201: subtotal=590, deliveryFee=300, total=890, назначен курьер, earnedPoints=8

### Проверяем, что остатки списались (роза была 100 -> 98, тюльпан 110 -> 109)
GET {{host}}/api/flowers
Accept: application/json

### Проверяем лояльность Анны (totalSpent=890, баллы +8)
GET {{host}}/api/clients/c0000000-0000-0000-0000-000000000001/loyalty
Accept: application/json

### Скачиваем счёт по заказу (id берётся из ответа orderSimple автоматически)
GET {{host}}/api/orders/{{orderSimple.response.body.$.id}}/invoice
Accept: text/plain


### =====================================================================
### СЦЕНАРИЙ B. Заказ готового букета у Анны
### =====================================================================

# @name orderBouquet
POST {{host}}/api/orders
Content-Type: application/json

{
  "clientId": "c0000000-0000-0000-0000-000000000001",
  "flowerIds": [],
  "bouquetIds": [
    "b0000000-0000-0000-0000-000000000001"
  ]
}
### Ожидаем 201: спишутся роза x1, тюльпан x2, эвкалипт x1.
### subtotal = (250+90+90+60) + 400 наценка = 890

### Проверяем остатки: тюльпан уменьшился ещё на 2, эвкалипт на 1
GET {{host}}/api/flowers
Accept: application/json


### =====================================================================
### СЦЕНАРИЙ C. Заказ с обычным промокодом SPRING20 (-20%)
### =====================================================================

# @name orderPromo
POST {{host}}/api/orders
Content-Type: application/json

{
  "clientId": "c0000000-0000-0000-0000-000000000001",
  "flowerIds": [
    "f0000000-0000-0000-0000-000000000003"
  ],
  "bouquetIds": [],
  "promocodeCode": "SPRING20"
}
### Ожидаем 201: subtotal=300, discountAmount=60 (20%), total=300-60+300=540

### Проверяем, что у промокода вырос usedCount
GET {{host}}/api/promocodes/SPRING20/validate
Accept: application/json


### =====================================================================
### СЦЕНАРИЙ D. VIP-промокод: сначала отказ Bronze, потом успех Gold
### =====================================================================

### D1. Анна (Bronze) пытается применить VIP30 -> ОЖИДАЕМ 400
POST {{host}}/api/orders
Content-Type: application/json

{
  "clientId": "c0000000-0000-0000-0000-000000000001",
  "flowerIds": [
    "f0000000-0000-0000-0000-000000000001"
  ],
  "bouquetIds": [],
  "promocodeCode": "VIP30"
}
### Ожидаем 400: "Промокод VIP30 доступен только клиентам уровня Gold и выше."

### D2. Мария делает крупный заказ (9 орхидей = 54000) -> станет Gold
POST {{host}}/api/orders
Content-Type: application/json

{
  "clientId": "c0000000-0000-0000-0000-000000000002",
  "flowerIds": [
    "f0000000-0000-0000-0000-000000000006",
    "f0000000-0000-0000-0000-000000000006",
    "f0000000-0000-0000-0000-000000000006",
    "f0000000-0000-0000-0000-000000000006",
    "f0000000-0000-0000-0000-000000000006",
    "f0000000-0000-0000-0000-000000000006",
    "f0000000-0000-0000-0000-000000000006",
    "f0000000-0000-0000-0000-000000000006",
    "f0000000-0000-0000-0000-000000000006"
  ],
  "bouquetIds": []
}
### total = 54000 + 300 = 54300 -> totalSpent >= 50000 -> Tier = Gold

### D3. Проверяем, что Мария теперь Gold
GET {{host}}/api/clients/c0000000-0000-0000-0000-000000000002/loyalty
Accept: application/json
### Ожидаем "tier": "Gold"

### D4. Теперь Мария применяет VIP30 -> УСПЕХ
POST {{host}}/api/orders
Content-Type: application/json

{
  "clientId": "c0000000-0000-0000-0000-000000000002",
  "flowerIds": [
    "f0000000-0000-0000-0000-000000000003"
  ],
  "bouquetIds": [],
  "promocodeCode": "VIP30"
}
### Ожидаем 201: discountAmount=90 (30% от 300), плюс бонусы x2 за Gold


### =====================================================================
### СЦЕНАРИЙ E. Нехватка остатков (хризантемы всего 5, заказываем 6) -> 400
### =====================================================================
POST {{host}}/api/orders
Content-Type: application/json

{
  "clientId": "c0000000-0000-0000-0000-000000000001",
  "flowerIds": [
    "f0000000-0000-0000-0000-000000000005",
    "f0000000-0000-0000-0000-000000000005",
    "f0000000-0000-0000-0000-000000000005",
    "f0000000-0000-0000-0000-000000000005",
    "f0000000-0000-0000-0000-000000000005",
    "f0000000-0000-0000-0000-000000000005"
  ],
  "bouquetIds": []
}
### Ожидаем 400: "Недостаточно цветов «Хризантема белая»: нужно 6, доступно 5."


### =====================================================================
### СЦЕНАРИЙ F. Смена статуса заказа
### =====================================================================

### F1. Создаём заказ для теста статусов
# @name orderForStatus
POST {{host}}/api/orders
Content-Type: application/json

{
  "clientId": "c0000000-0000-0000-0000-000000000001",
  "flowerIds": [
    "f0000000-0000-0000-0000-000000000002"
  ],
  "bouquetIds": []
}

### F2. Переход Created -> Assigned (ОК)
PUT {{host}}/api/orders/{{orderForStatus.response.body.$.id}}/status
Content-Type: application/json

{
  "status": "Assigned"
}

### F3. Попытка перепрыгнуть Assigned -> Delivered (минуя InDelivery) -> 400
PUT {{host}}/api/orders/{{orderForStatus.response.body.$.id}}/status
Content-Type: application/json

{
  "status": "Delivered"
}
### Ожидаем 400: "Недопустимый переход..."

### F4. Корректно: Assigned -> InDelivery
PUT {{host}}/api/orders/{{orderForStatus.response.body.$.id}}/status
Content-Type: application/json

{
  "status": "InDelivery"
}

### F5. InDelivery -> Delivered (ОК)
PUT {{host}}/api/orders/{{orderForStatus.response.body.$.id}}/status
Content-Type: application/json

{
  "status": "Delivered"
}


### =====================================================================
### СЦЕНАРИЙ G. Отмена заказа с возвратом (главный козырь)
### =====================================================================

### G1. Создаём заказ (3 лилии)
# @name orderToCancel
POST {{host}}/api/orders
Content-Type: application/json

{
  "clientId": "c0000000-0000-0000-0000-000000000001",
  "flowerIds": [
    "f0000000-0000-0000-0000-000000000003",
    "f0000000-0000-0000-0000-000000000003",
    "f0000000-0000-0000-0000-000000000003"
  ],
  "bouquetIds": []
}

### G2. Смотрим остаток лилий ДО отмены (запомни число)
GET {{host}}/api/flowers/f0000000-0000-0000-0000-000000000003
Accept: application/json

### G3. Отменяем заказ -> 204
PUT {{host}}/api/orders/{{orderToCancel.response.body.$.id}}/cancel

### G4. Смотрим остаток лилий ПОСЛЕ отмены — должен вырасти на 3 (возврат на склад)
GET {{host}}/api/flowers/f0000000-0000-0000-0000-000000000003
Accept: application/json

### G5. Повторная отмена того же заказа -> 400 "Заказ уже отменён."
PUT {{host}}/api/orders/{{orderToCancel.response.body.$.id}}/cancel


### =====================================================================
### СЦЕНАРИЙ H. Ошибки 404 и 400
### =====================================================================

### H1. Несуществующий клиент -> 404
GET {{host}}/api/clients/00000000-0000-0000-0000-000000000000
Accept: application/json

### H2. Несуществующий заказ -> 404
GET {{host}}/api/orders/00000000-0000-0000-0000-000000000000
Accept: application/json

### H3. Пустой заказ (ни цветов, ни букетов) -> 400
POST {{host}}/api/orders
Content-Type: application/json

{
  "clientId": "c0000000-0000-0000-0000-000000000001",
  "flowerIds": [],
  "bouquetIds": []
}
### Ожидаем 400: "Заказ должен содержать хотя бы один цветок или букет."

### H4. Заказ с несуществующим клиентом -> 400
POST {{host}}/api/orders
Content-Type: application/json

{
  "clientId": "00000000-0000-0000-0000-000000000000",
  "flowerIds": [
    "f0000000-0000-0000-0000-000000000001"
  ],
  "bouquetIds": []
}
### Ожидаем 400: "Клиент не найден."


### =====================================================================
### Список всех заказов в конце
### =====================================================================
GET {{host}}/api/orders
Accept: application/json